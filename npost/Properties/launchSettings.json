        "ASPNETCORE_HTTP_PORTS": "8080",
        "ASPNETCORE_ENVIRONMENT": "Development",
        "PGHOST": "localhost",
        "PGUSER": "postgres",
        "PGPASSWORD": "1234",
        "PGPORT": "5432",
        "JWT_SECRETKEY": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
      },
      "publishAllPorts": true,
      "useSSL": false
    }
  }
